# === Aplikacja ===
NEXT_PUBLIC_SITE_URL=https://smartobywatel.pl

# === Sanity (treść) ===
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_REVALIDATE_SECRET=

# === Supabase (Postgres + Auth + Storage, region EU) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL: połączenie pooled (pgbouncer) do aplikacji.
# DIRECT_URL: połączenie bezpośrednie do migracji Prisma.
DATABASE_URL=
DIRECT_URL=

# === Płatności: Przelewy24 ===
PAYMENT_PROVIDER=przelewy24
P24_MERCHANT_ID=
P24_POS_ID=
P24_CRC=
P24_API_KEY=
P24_SANDBOX=true

# === Fakturownia ===
FAKTUROWNIA_DOMAIN=
FAKTUROWNIA_API_TOKEN=
FAKTUROWNIA_SELLER_NAME=Smart Obywatel
# Typ dokumentu: "bill" (rachunek, nie-VAT) -> po przejściu na VAT zmień na "vat".
FAKTUROWNIA_INVOICE_KIND=bill
# Stawka podatku dla pozycji: "disabled" (nie-VAT) lub np. 23.
FAKTUROWNIA_TAX=disabled

# === Brevo (e-mail transakcyjny + newsletter) ===
BREVO_API_KEY=
BREVO_NEWSLETTER_LIST_ID=
BREVO_SENDER_EMAIL=no-reply@smartobywatel.pl
BREVO_SENDER_NAME=Smart Obywatel
PARTNER_LEAD_EMAIL=

# Klucz pliku darmowego wzoru (lead magnet) w prywatnym buckecie "lead-magnets".
LEAD_MAGNET_STORAGE_KEY=

# === Analityka: Plausible (EU) ===
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# === Cal.com (konsultacje) ===
NEXT_PUBLIC_CALCOM_LINK=
