# === Aplikacja ===
NEXT_PUBLIC_SITE_URL=https://smartobywatel.pl

# === Sanity (treść) ===
# ID projektu i dataset z sanity.io/manage. Publiczne (prefiks NEXT_PUBLIC_),
# używane też przez osadzone Studio pod /studio. Puste = tryb bez CMS
# (aplikacja korzysta z bezpiecznego fallbacku, build nie pada).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Wersja API Sanity (data). Zostaw domyślną, chyba że migrujesz na nowszą.
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Token odczytu (Viewer) — wymagany tylko dla treści roboczych/preview.
# Publiczne treści pobierane są przez CDN bez tokenu.
SANITY_API_READ_TOKEN=
# Sekret webhooka rewalidacji ISR (Sanity -> /api/revalidate).
SANITY_REVALIDATE_SECRET=

# === Supabase (Postgres + Auth + Storage, region EU) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL: połączenie pooled (pgbouncer) do aplikacji.
# DIRECT_URL: połączenie bezpośrednie do migracji Prisma.
DATABASE_URL=
DIRECT_URL=

# === Płatności: Przelewy24 ===
PAYMENT_PROVIDER=przelewy24
P24_MERCHANT_ID=
P24_POS_ID=
P24_CRC=
P24_API_KEY=
P24_SANDBOX=true

# === Fakturownia ===
FAKTUROWNIA_DOMAIN=
FAKTUROWNIA_API_TOKEN=
FAKTUROWNIA_SELLER_NAME=Smart Obywatel
# Typ dokumentu: "bill" (rachunek, nie-VAT) -> po przejściu na VAT zmień na "vat".
FAKTUROWNIA_INVOICE_KIND=bill
# Stawka podatku dla pozycji: "disabled" (nie-VAT) lub np. 23.
FAKTUROWNIA_TAX=disabled

# === Brevo (e-mail transakcyjny + newsletter) ===
BREVO_API_KEY=
BREVO_NEWSLETTER_LIST_ID=
BREVO_SENDER_EMAIL=no-reply@smartobywatel.pl
BREVO_SENDER_NAME=Smart Obywatel
PARTNER_LEAD_EMAIL=
# Fallback kodu partnera dla leadów (gdy brak w URL i w ustawieniach CMS).
DEFAULT_PARTNER_CODE=direct

# Klucz pliku darmowego wzoru (lead magnet) w prywatnym buckecie "lead-magnets".
LEAD_MAGNET_STORAGE_KEY=

# === Analityka: Plausible Cloud (EU) ===
# Privacy-first, bez cookies (nie wymaga banera zgód RODO); dane hostowane w UE.
# Analityka włącza się TYLKO gdy ustawisz domenę poniżej — puste = wyłączona
# (np. w developmencie). Domena = ta zarejestrowana w panelu Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Endpoint skryptu. Domyślnie oficjalny Plausible Cloud (UE). Zmień na własny
# adres tylko przy self-hoście lub proxy skryptu.
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# === Cal.com (konsultacje) ===
# Pełny link Cal.com Cloud do typu wydarzenia „konsultacja", np.
# https://cal.com/twoj-uzytkownik/konsultacja. Strona /konsultacje OSADZA ten
# link jako inline embed. Płatność (Stripe, z góry) konfigurujesz w panelu typu
# wydarzenia Cal.com (aplikacja Stripe + płatność przed rezerwacją) — nie w kodzie.
# Ustawienie w Sanity (`calcomLink`) ma priorytet nad tą zmienną. Puste = strona
# pokazuje komunikat „dostępne wkrótce" (build przechodzi bez konfiguracji).
NEXT_PUBLIC_CALCOM_LINK=
